# SQLite database (Prisma reads this from .env)
DATABASE_URL="file:./dev.db"

# Google Maps — browser key (Maps JS), restrict by HTTP referrer.
# Read at RUNTIME on the server and handed to the client, so it is NOT baked into
# the build/image (one image → many envs, rotate without rebuild).
GOOGLE_MAPS_BROWSER_KEY=""
# Optional Map ID for Advanced Markers (use "DEMO_MAP_ID" for local dev).
GOOGLE_MAPS_MAP_ID="DEMO_MAP_ID"
# Local-dev fallback: if the GOOGLE_MAPS_* vars above are unset, these NEXT_PUBLIC_
# names are still honoured, so existing local .env files keep working.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID="DEMO_MAP_ID"

# Google Maps — server key (Geocoding/Places/Routes), restrict by IP/API
GOOGLE_MAPS_SERVER_KEY=""

# --- Authentication (Google OIDC) ---
# Google OAuth 2.0 Web client (Cloud Console → Credentials).
# Authorized redirect URI: ${APP_URL}/api/auth/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Secret used to sign the session JWT. Generate: openssl rand -base64 32
AUTH_SECRET=""
# Base URL of the app (used to build the OAuth redirect URI)
APP_URL="http://localhost:5001"
# Comma-separated emails allowed to sign in. EMPTY = everyone allowed (open mode).
# Shared users are always admitted regardless of this list.
ALLOWED_EMAILS=""

# --- DEV-ONLY auth bypass (local design/QA without the Google flow) ---
# Hard-gated: completely inert when NODE_ENV=production. When NODE_ENV is not
# production AND DEV_AUTH_BYPASS="1", getSession() signs in as DEV_AUTH_EMAIL
# (or the first ALLOWED_EMAILS entry) if that user exists. NEVER set these in a
# deployed environment.
DEV_AUTH_BYPASS=""
DEV_AUTH_EMAIL=""

# --- MCP server (mcp/server.ts) ---
# Email of the owner the MCP server acts as. Defaults to the first ALLOWED_EMAILS
# entry when left empty. The MCP server also needs DATABASE_URL,
# GOOGLE_MAPS_SERVER_KEY (search/geocode) and AUTH_SECRET (imported via lib/db).
MCP_OWNER_EMAIL=""
# Required to enable the HTTP endpoint POST /api/mcp. A long random secret used
# as a static bearer token. If unset, the endpoint rejects ALL requests
# (fail-closed). MCP_OWNER_EMAIL still selects which user the server acts as.
MCP_AUTH_TOKEN=""
